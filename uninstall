#!/usr/bin/env bash
# zstack uninstall: reverse what ./setup created, honoring the SAME ownership
# rule setup uses -- never remove anything we cannot prove we created.
#
#   owned    := a symlink under one of our managed names WHOSE TARGET resolves
#               into this pack (setup only ever links to PACK_DIR or a skill dir
#               within it), OR a directory carrying the .zstack-registered
#               sentinel setup drops into every COPIED registration (the Windows
#               install path).
#   not-ours := a same-named directory with neither, OR a same-named symlink whose
#               target points OUTSIDE the pack (a user's own z-* link) -> left
#               untouched, and named.
#
# Removes the "zstack" pack registration (and, defensively, any separately
# registered z-* skill entry) from each host skills dir that exists. When a
# host's "zstack" IS the git clone this script runs from (the parent-match case,
# mirrors setup's), the clone is LEFT in place -- it may be your only copy -- and
# the exact `rm -rf` command is printed for you to run by hand.
#
# Order: other hosts first, the running host (Claude Code) last, so the command
# deletes its own registration as its final act.
#
# --purge additionally removes ~/.zstack (project configs, loop state, locks,
# reports, loop-counter). Without it, ~/.zstack is left and its path plus the
# purge command are printed.
#
# HOME-scoped throughout ($HOME/.claude, $HOME/.zstack, ...): a test can point
# HOME at a fixture dir and this script never touches the real ones.
set -e

SENTINEL=".zstack-registered"   # kept in sync with the same literal in ./setup

PURGE=0
for arg in "$@"; do
  case "$arg" in
    --purge) PURGE=1 ;;
    -h|--help)
      echo "Usage: uninstall [--purge]"
      echo "  Remove the zstack registrations we own from each host skills dir."
      echo "  --purge   also delete ~/.zstack (project configs, loop state, locks, reports)."
      exit 0
      ;;
    *) echo "uninstall: unknown argument '$arg' (expected --purge)." >&2; exit 2 ;;
  esac
done

PACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# shellcheck source=lib/realpath.sh
. "$PACK_DIR/lib/realpath.sh"

# setup registers the pack as "zstack"; the shipped z-* skills live inside it.
# We also sweep the individual z-* names so a hand-made per-skill registration
# is cleaned too -- each removed only when owned, exactly like the pack entry.
# Derived the same way setup's register() finds them (setup:143 -- PACK_DIR/z-*/
# dirs carrying SKILL.md), not hand-listed: a hardcoded array here previously
# went stale the moment #36 added z-update, orphaning it on every uninstall.
ENTRIES=(zstack)
for skill_dir in "$PACK_DIR"/z-*/; do
  [ -f "$skill_dir/SKILL.md" ] || continue
  ENTRIES+=("$(basename "$skill_dir")")
done

removed=0
left=0
clone_left=()

# Remove one named entry from a host skills dir if -- and only if -- we own it.
remove_entry() {
  local skills_dir="$1" name="$2"
  local path="$skills_dir/$name"

  # Absent (and not a dangling symlink) -> nothing to do.
  if [ ! -e "$path" ] && [ ! -L "$path" ]; then
    return 0
  fi

  # A symlink under our managed name is ours ONLY when it resolves INTO this pack
  # (setup only ever links to PACK_DIR or a skill dir within it). A user's own
  # symlink named z-* that points elsewhere is NOT ours -- removing it would break
  # their link, so leave-and-name it like an un-sentineled dir. `_realpath`
  # canonicalizes even a dangling link (parent still present), so a stale link of
  # ours is still cleaned; an unresolved/foreign target (empty or outside) is
  # left. Removing the link itself never touches its target. Checked before -d,
  # which follows links.
  if [ -L "$path" ]; then
    local target_real
    target_real="$(_realpath "$path" || true)"
    case "$target_real" in
      "$PACK_DIR"|"$PACK_DIR"/*)
        rm -f "$path"
        echo "  removed $path (symlink into the pack)"
        removed=$((removed + 1))
        ;;
      *)
        echo "  left $path -- symlink to ${target_real:-an unresolved target} outside the zstack pack; not created by zstack, left untouched."
        left=$((left + 1))
        ;;
    esac
    return 0
  fi

  if [ -d "$path" ]; then
    local real
    real="$(cd "$path" && pwd -P)"

    # (a) The dir we're running from (parent-match): we cannot delete the pack out
    #     from under the running script. The message splits on the sentinel:
    #       - a sentinel-carrying COPY (a Windows registration executing its own
    #         uninstall) IS provably ours, but it has a source elsewhere -- name it
    #         honestly as a registered copy and print the manual removal command,
    #         NOT the "may be your only copy" clone warning (that source is safe).
    #       - a bare clone with no sentinel may be your ONLY copy -- warn, remember
    #         it, print the exact rm -rf in the closing summary.
    if [ "$real" = "$PACK_DIR" ]; then
      if [ -f "$path/$SENTINEL" ]; then
        echo "  left $path -- this is the running zstack registered copy; the source it was copied from owns the install. Remove this copy from there, or by hand:"
        echo "    rm -rf \"$path\""
      else
        echo "  left $path -- this is the zstack clone itself (may be your only copy); not deleted."
        clone_left+=("$path")
      fi
      left=$((left + 1))
      return 0
    fi

    # (b) A copy carrying our sentinel (and NOT the running dir) is ours to remove.
    if [ -f "$path/$SENTINEL" ]; then
      rm -rf "$path"
      echo "  removed $path (zstack-created copy)"
      removed=$((removed + 1))
      return 0
    fi

    # (c) No proof of ownership -> leave it, name it.
    echo "  left $path -- not created by zstack (no symlink, no $SENTINEL); left untouched."
    left=$((left + 1))
    return 0
  fi

  # A non-directory, non-symlink file under the name: not something we make.
  echo "  left $path -- unexpected file (not a zstack registration); left untouched."
  left=$((left + 1))
  return 0
}

# Other hosts first, Claude Code (the running host) last.
HOST_DIRS=("$HOME/.codex/skills" "$HOME/.factory/skills" "$HOME/.claude/skills")
HOST_LABELS=("Codex" "Factory" "Claude Code")

for i in "${!HOST_DIRS[@]}"; do
  skills_dir="${HOST_DIRS[$i]}"
  [ -d "$skills_dir" ] || continue
  echo "${HOST_LABELS[$i]} ($skills_dir):"
  for name in "${ENTRIES[@]}"; do
    remove_entry "$skills_dir" "$name"
  done
done

# ~/.zstack: per-project state. Removed only under --purge.
ZSTACK_DIR="$HOME/.zstack"
if [ -d "$ZSTACK_DIR" ]; then
  if [ "$PURGE" -eq 1 ]; then
    rm -rf "$ZSTACK_DIR"
    echo "purged $ZSTACK_DIR (project configs, loop state, locks, reports, loop-counter)."
    removed=$((removed + 1))
  else
    echo "left $ZSTACK_DIR (project configs, loop state, locks, reports, loop-counter)."
    echo "  to remove it too: rm -rf \"$ZSTACK_DIR\"   (or re-run: \"$PACK_DIR/uninstall\" --purge)"
    left=$((left + 1))
  fi
fi

# Clones we refused to delete: print the exact command the human can run.
if [ "${#clone_left[@]}" -gt 0 ]; then
  echo ""
  echo "Left the zstack clone in place (deleting it may remove your only copy). To remove it too:"
  for p in "${clone_left[@]}"; do
    echo "  rm -rf \"$p\""
  done
fi

# GitHub-side artifacts (board, milestones, labels) are remote data. This script
# never reaches the network; the z-uninstall skill reminds you they persist.

if [ "$removed" -eq 0 ] && [ "$left" -eq 0 ]; then
  echo "Nothing to remove -- no zstack registrations found."
fi

echo "zstack uninstall complete."
exit 0
