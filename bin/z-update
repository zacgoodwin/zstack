#!/usr/bin/env bash
# zstack update: resolve the git clone that backs this install, pull it
# --ff-only, then re-run its setup so every registered skill refreshes.
#
# Self-replacement hazard: this script and setup both live inside the git
# source `git pull` rewrites. Bash reads a script's bytes incrementally as it
# executes, so if `pull` mutates bin/z-update's own file mid-run, anything
# read AFTER that point can be misaligned garbage. A `name() { ... }` function
# body is a single compound command -- bash's parser must read all the way to
# the matching `}` before executing any of it -- so wrapping the pull-onward
# logic in main() forces the WHOLE thing into the parser before the pull ever
# runs. main's own last statement is `exec`, which replaces this process with
# setup's, so control never falls back into (possibly-rewritten) bin/z-update
# afterward either.
set -e

MARKER=".zstack-registered"   # kept in sync with the same literal in ./setup

# Resolve the pack dir this script is running from. `pwd -P` resolves through
# any symlink in the path (the macOS/Linux registration is `skills/zstack ->
# real clone`), so a symlinked .../zstack/bin/z-update already lands on the
# real clone here -- no separate readlink step needed.
HERE="$(cd "$(dirname "$0")" && pwd -P)"
PACK_DIR="$(cd "$HERE/.." && pwd -P)"

# Resolve the git source to pull, in priority order:
#   1. PACK_DIR itself is a git checkout (a direct clone, or a symlinked
#      registration already resolved to its real clone by pwd -P above).
#      `-e`, not `-d`: `git worktree add` produces a `.git` FILE, not a dir.
#   2. PACK_DIR is a sentinel copy (the Windows install path) whose marker
#      names the clone it was copied from.
resolve_source() {
  if [ -e "$PACK_DIR/.git" ]; then
    printf '%s\n' "$PACK_DIR"
    return 0
  fi
  local marker="$PACK_DIR/$MARKER" src
  if [ -f "$marker" ]; then
    src="$(sed -n 's/^source: //p' "$marker" | tail -1)"
    if [ -n "$src" ] && [ -e "$src/.git" ]; then
      printf '%s\n' "$src"
      return 0
    fi
  fi
  return 1
}

if ! SRC="$(resolve_source)"; then
  echo "zstack update: no git source found for this install (ZIP/manual copy, or a legacy marker with no recorded source)." >&2
  echo "Reinstall from git to enable updates:" >&2
  echo "  git clone https://github.com/zacgoodwin/zstack.git ~/.claude/skills/zstack" >&2
  echo "  cd ~/.claude/skills/zstack && ./setup" >&2
  exit 1
fi

main() {
  local old_version new_version
  old_version="$(cat "$SRC/VERSION" 2>/dev/null || echo unknown)"

  # set -e stops here (surfacing git's own error on stderr) if the pull
  # fails, e.g. diverged local commits -- setup never runs, nothing changes.
  git -C "$SRC" pull --ff-only

  new_version="$(cat "$SRC/VERSION" 2>/dev/null || echo unknown)"
  echo "zstack update: $old_version -> $new_version"

  exec "$SRC/setup" --team "$@"
}
main "$@"
