#!/usr/bin/env bash
# One per-iteration drain tick for /z-loop (ticket #57, Leak 2): snapshot the
# board -> ingest it into the loop state -> ask the state machine for the next
# Action, printing ONLY that one-line Action JSON on stdout. Collapsing the old
# ~15-line snapshot+ingest+next block into this single wrapper stops the repeated
# bash command TEXT from re-entering the orchestrator's context on every one of a
# long drain's 100+ iterations.
#
# It shells only z-board and bun -- never the GitHub CLI directly. Bodies come
# from `z-board snapshot` (which fetches them through lib/board.ts, the sole
# sanctioned GitHub caller), so this wrapper stays free of any direct GitHub
# call and the caller gate in tests/board.test.ts keeps holding.
#
# It also runs the human-needed safety control (issue #63) every tick: writes
# the parked-tickets breakdown to $TMP/human-needed.json and, the moment it
# first crosses BoardConfig.humanNeededPercent, fires the one-time mid-run
# notification through lib/notify.ts -- same reasoning as above, a periodic
# per-tick check belongs in this wrapper, not a second bash block in
# z-loop/SKILL.md re-entering the orchestrator's context every iteration.
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd -P)"
PACK="$(cd "$HERE/.." && pwd -P)"
# z-board resolution: an explicit $Z_BOARD wins (the loop preamble exports it,
# and the gate test injects a stub through it); otherwise prefer one on PATH,
# then the sibling in this bin dir. Never resolves to anything but a z-board.
Z_BOARD="${Z_BOARD:-$(command -v z-board 2>/dev/null || echo "$HERE/z-board")}"

SLUG=""; STATE=""; TMP=""
while [ $# -gt 0 ]; do
  case "$1" in
    --slug) SLUG="$2"; shift 2 ;;
    --state) STATE="$2"; shift 2 ;;
    --tmp) TMP="$2"; shift 2 ;;
    *) echo "z-loop-tick: unknown argument '$1'" >&2; exit 1 ;;
  esac
done
if [ -z "$SLUG" ] || [ -z "$STATE" ] || [ -z "$TMP" ]; then
  echo "usage: z-loop-tick --slug <slug> --state <state.json> --tmp <dir>" >&2
  exit 1
fi

mkdir -p "$TMP"
# 0. Throttle (issue #58): sleep out the remainder of the project's
#    tickThrottleSeconds (config.json, default 0 = off) since the last tick,
#    then stamp this tick's start time. Proactive pacing that keeps
#    ProjectsV2 GraphQL spend under GitHub's 5k/hr budget, complementing the
#    reactive enforceQuota() backstop in lib/board.ts. No-op at the 0
#    default -- today's behavior unchanged.
bun "$PACK/lib/throttle.ts" wait --slug "$SLUG" >/dev/null
# 1. Snapshot: all-status items + each ticket's body, one call, to files.
"$Z_BOARD" snapshot --slug "$SLUG" --out-items "$TMP/items.json" --out-bodies "$TMP/bodies.json" >/dev/null
# 1b. Live context reading (issue #131): how full the orchestrator's OWN
#     context window is right now, measured deterministically from its session
#     transcript. Fail-open by construction -- an unresolvable/unreadable
#     transcript prints 0, and the `|| echo 0` backstops any hard error -- so a
#     bad reading degrades to pre-#131 behavior (no gating) and NEVER wedges the
#     drain. Threaded into the ingest below as --context-tokens so the context
#     gate lives in the pure state machine, not this wrapper. --project-dir is
#     this wrapper's cwd = the orchestrator's cwd, whose mangled form names the
#     transcript dir.
CTX=$(bun "$PACK/lib/context-budget.ts" current --project-dir "$PWD" 2>/dev/null || echo 0)
[ -z "$CTX" ] && CTX=0
# 2a. Graceful stop sentinel (#132): z-stop drops a "stop-requested" file next to
#     state.json (lib/stop.ts stopSentinelPath == STATE_DIR/stop-requested). A
#     plain file test -- no per-tick bun spawn on a 100+ iteration drain -- passes
#     --stop-requested to ingest so the loop pulls no new work and drains to exit.
#     The "stop-requested" literal is shared with lib/stop.ts; keep the two in sync.
STOP_FLAG=""
if [ -f "$(dirname "$STATE")/stop-requested" ]; then STOP_FLAG="--stop-requested"; fi
# 2. Ingest: refresh ticket statuses; preserves lanes + lost-claim flags (no
#    config flags here -- Step 3's first ingest already set maxLanes/watchdog);
#    threads the fresh context reading (contextTokenLimit was captured at Step 3).
bun "$PACK/lib/loop.ts" ingest "$STATE" "$TMP/items.json" "$TMP/bodies.json" --context-tokens "$CTX" $STOP_FLAG >/dev/null
# 2b. Human-needed safety control (issue #63): recompute the parked-tickets
# breakdown every tick (read-only) and fire the ONE-TIME mid-run breakdown
# notification the instant it first crosses BoardConfig.humanNeededPercent.
# Lives here -- not lib/loop.ts (which stays pure/network-free) and not a
# second per-tick block back in z-loop/SKILL.md -- so the check rides the same
# single-call-per-iteration cadence #57 already collapsed the drain loop into.
# The fire-once flag is set ONLY after notify.ts reports "sent": an
# unconfigured project or a down webhook must never wedge the ack, so the real
# notification still fires once it can actually be delivered. Never aborts the
# tick (`|| true`): a safety-control hiccup must not block the drain.
bun "$PACK/lib/loop.ts" human-needed "$STATE" > "$TMP/human-needed.json"
if [ "$(jq -r .tripped "$TMP/human-needed.json")" = "true" ] && [ "$(jq -r .alreadyNotified "$TMP/human-needed.json")" != "true" ]; then
  SENT=$(bun "$PACK/lib/notify.ts" send human-needed "$TMP/human-needed.json" --slug "$SLUG" 2>/dev/null) || SENT="error"
  [ "$SENT" = "sent" ] && bun "$PACK/lib/loop.ts" human-needed-ack "$STATE" >/dev/null || true
fi
# 3. Next: print exactly one Action JSON line -- the only thing the caller reads.
bun "$PACK/lib/loop.ts" next "$STATE"
