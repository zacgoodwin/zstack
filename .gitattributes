# Auto detect text files and perform LF normalization
* text=auto

# The `setup` script is bash, checked in without a .sh suffix. Without this,
# Windows checkouts with core.autocrlf=true rewrite it to CRLF, which breaks
# bash keywords ("fi\r", "then\r" aren't recognized). Same fix as gstack's setup.
setup   text eol=lf
uninstall text eol=lf
bin/z-board text eol=lf
bin/z-estimate text eol=lf
bin/z-cost text eol=lf
bin/z-setup-board text eol=lf
bin/z-setup-permissions text eol=lf
bin/z-ticket-lint text eol=lf
bin/z-update text eol=lf
bin/z-loop-tick text eol=lf
bin/z-cost-suggest text eol=lf
# Extensionless bash in the eval fixture app; same CRLF hazard as setup.
evals/fixture-app/scripts/deploy text eol=lf
# Every checked-in bash script, wherever it lives: the eval harnesses, and
# lib/realpath.sh, which `setup` and `uninstall` SOURCE -- a CRLF copy of a
# sourced file breaks both installers the same way it breaks setup itself.
*.sh    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf
*.toml  text eol=lf
# The reviewer single-pass golden (issue #59): a byte-for-byte snapshot of the
# pre-#59 prompt, compared against reviewerPrompt(input, false) output. That
# output is LF (its *.ts source is eol=lf), so the golden must stay LF too or the
# comparison would spuriously fail on a CRLF Windows checkout.
tests/reviewer-single-pass.golden.txt text eol=lf

# Diagrams: never touch bytes.
*.png binary
