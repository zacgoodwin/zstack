+// Membership test for a fixed rate-limit window that opens at `start` and lasts
+// `durationMs`. The window is half-open [start, start + durationMs): the start
+// tick is inside, the end tick belongs to the next window.
+export function withinWindow(now: number, start: number, durationMs: number): boolean {
+  if (durationMs <= 0) return false;
+  const end = start + durationMs;
+  // A request is in this window when it is at/after the open and before the end.
+  return now >= start && now <= end;
+}
diff --git a/src/window.test.ts b/src/window.test.ts
