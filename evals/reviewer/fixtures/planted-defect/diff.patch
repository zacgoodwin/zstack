@@ -0,0 +1,12 @@
+import { test, expect } from "bun:test";
+import { withinWindow } from "./window.ts";
+
+test("a request at the exact window open is inside", () => {
+  expect(withinWindow(1000, 1000, 500)).toBe(true);
+});
+test("a request one ms before the boundary is inside", () => {
+  expect(withinWindow(1499, 1000, 500)).toBe(true);
+});
+test("a request before the window is outside", () => {
+  expect(withinWindow(999, 1000, 500)).toBe(false);
+});
