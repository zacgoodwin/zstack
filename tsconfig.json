{
  // Typecheck-only config (issue #14 item 20): bun executes the .ts directly,
  // so tsc never emits -- settings mirror how bun actually runs this code
  // (ESM, .ts-extension imports, bundler-style resolution, Bun globals).
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"]
  },
  // The pack's own code: lib/ + gate tests + the e2e checker the tests import,
  // plus (issue #25) the planner harness's two .ts files, named explicitly
  // rather than as "evals/planner" so the directory pattern does not also pull
  // in evals/planner/fixture-app/ -- a separate package with its own
  // package.json, same as evals/fixture-app and deliberately not part of this
  // project either.
  "include": ["lib", "tests", "evals/e2e", "evals/planner/harness.ts", "evals/planner/board-double.ts"]
}
